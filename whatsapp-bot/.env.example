# ==========================================
# WhatsApp Chatbot Environment Configuration
# ==========================================

# --------------------------
# General App Settings
# --------------------------
# Enable debug mode for more verbose logging (True/False)
DEBUG=False

# --------------------------
# Database Configuration
# --------------------------
# Connection string for SQLAlchemy (e.g., SQLite, PostgreSQL)
DATABASE_URL=sqlite:///./data/chatbot.db

# --------------------------
# AI Provider (Anthropic)
# --------------------------
# Your Anthropic API key to use Claude for intent classification and entity extraction
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --------------------------
# Meta WhatsApp Cloud API
# --------------------------
# The Phone Number ID provided in your Meta App Dashboard
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# The Access Token (Temporary or Permanent) for the WhatsApp Business Account
WHATSAPP_ACCESS_TOKEN=your_access_token

# A custom secret string used to verify your webhook during initial Meta setup
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_string

# --------------------------
# Human Handoff Settings
# --------------------------
# The phone number (with country code) of the human agent who will receive handoff alerts
HUMAN_AGENT_NUMBER=+1234567890

# --------------------------
# Admin Panel Authentication
# --------------------------
# HTTP Basic Auth credentials for the /admin API endpoints
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_password
